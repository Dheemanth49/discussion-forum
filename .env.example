# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/discussion_forum
DB_HOST=localhost
DB_PORT=5432
DB_NAME=discussion_forum
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_DDL_AUTO=validate
DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/discussion_forum
EMBEDDING_DATABASE_URL=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_should_be_long_and_secure
JWT_EXPIRATION=86400000

# Initial Admin User Configuration
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@forum.com
INITIAL_ADMIN_PASSWORD=admin_password

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend Configuration
VITE_API_URL=http://localhost:8080/api

# Embedding Service
EMBEDDING_SERVICE_URL=http://localhost:7645
EMBEDDING_SERVICE_HOST=localhost
EMBEDDING_SERVICE_PORT=7645
FLASK_HOST=0.0.0.0
FLASK_PORT=7645
FLASK_DEBUG=false

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Gemini API
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
